# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — required by the reminder cron to read settings and query
# prices server-side (bypasses RLS; never expose to the browser).
SUPABASE_SERVICE_ROLE_KEY=

# Registration whitelist (comma-separated emails)
AUTHORIZED_EMAILS=

# Resend (weekly price-reminder email)
RESEND_API_KEY=

# Secret used to authenticate Vercel Cron requests to /api/cron/*
CRON_SECRET=
